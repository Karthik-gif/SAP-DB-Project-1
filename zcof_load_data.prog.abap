  " Convert string amounts to packed decimals via MOVE
  DATA: ls_row   TYPE ty_cof,
        ls_data  TYPE ztcof_data,
        lt_data  TYPE TABLE OF ztcof_data.

  LOOP AT lt_cof INTO ls_row.
    CLEAR ls_data.
    MOVE-CORRESPONDING ls_row TO ls_data.
    " Numeric string conversions
    ls_data-opening_amt          = ls_row-opening_amt.
    ls_data-addition_amt         = ls_row-addition_amt.
    ls_data-redemption_amt       = ls_row-redemption_amt.
    ls_data-closing_amt          = ls_row-closing_amt.
    ls_data-accrual_amt          = ls_row-accrual_amt.
    ls_data-wt_avg_amt           = ls_row-wt_avg_amt.
    ls_data-avg_funds            = ls_row-avg_funds.
    ls_data-open_eir             = ls_row-open_eir.
    ls_data-exit_eir             = ls_row-exit_eir.
    ls_data-wt_int_amt_eir       = ls_row-wt_int_amt_eir.
    ls_data-avg_rate_eir         = ls_row-avg_rate_eir.
    ls_data-avg_rate_eir_papm    = ls_row-avg_rate_eir_papm.
    ls_data-exit_rate            = ls_row-exit_rate.
    ls_data-exit_spread          = ls_row-exit_spread.
    ls_data-exit_final_rate      = ls_row-exit_final_rate.
    ls_data-exit_final_rate_papm = ls_row-exit_final_rate_papm.
    ls_data-avg_rate_yield       = ls_row-avg_rate_yield.
    ls_data-avg_rate_yield_papm  = ls_row-avg_rate_yield_papm.
    ls_data-wt_int_amt_cyl       = ls_row-wt_int_amt_cyl.
    ls_data-wt_amt_cyl           = ls_row-wt_amt_cyl.
    APPEND ls_data TO lt_data.
  ENDLOOP.

  " Delete existing and reload
  DELETE FROM ztcof_data.
  COMMIT WORK.

  MODIFY ztcof_data FROM TABLE @lt_data.

  IF sy-subrc = 0.
    lv_lines = lines( lt_data ).
    lv_msg = |{ lv_lines } COF records loaded successfully.|.
    WRITE: / lv_msg.
  ELSE.
    WRITE: / 'ERROR: MODIFY failed. Check table ZTCOF_DATA activation.'.
  ENDIF.

  COMMIT WORK.
  WRITE: / 'Data load complete.'.